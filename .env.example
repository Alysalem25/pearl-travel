# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=your_secure_password_here
MONGO_DATABASE=pearl_travel

# Node Environment
NODE_ENV=production

# Frontend Configuration
# Nginx acts as reverse proxy, so use domain without port
# For HTTP: http://your-domain.com
# For HTTPS: https://your-domain.com (recommended)
NEXT_PUBLIC_API_URL=https://your-domain.com

# Backend Configuration (add your specific environment variables)
PORT=5000
# JWT_SECRET=your_jwt_secret_here
# Add other backend environment variables as needed
